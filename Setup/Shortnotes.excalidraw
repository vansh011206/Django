    {
      "id": "j9rvCqH346HklOJyZ7_8C",
      "type": "text",
      "x": -107.76190476190482,
      "y": 431.1666666666665,
      "width": 839.2593994140625,
      "height": 250,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a0",
      "roundness": null,
      "seed": 1597655971,
      "version": 270,
      "versionNonce": 67287245,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783660303979,
      "link": null,
      "locked": false,
      "text": "Template → Dynamic HTML banata hai.\nVariable ({{ }}) → Data dikhata hai.\nTag ({% %}) → Logic likhne ke liye.\nFilter (|) → Data modify karta hai.\nContext → View se Template me bheja gaya data (Dictionary).\nrender() → Template + Context = HTML.\nDIRS → Template folder ka path.\nAPP_DIRS=True → Apps ke templates bhi search karega.\n{% load static %} → CSS, JS, Images use karne ke liye.\n{{ student.name }} → Dot notation se Dictionary/Object/List access kar sakte hain.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Template → Dynamic HTML banata hai.\nVariable ({{ }}) → Data dikhata hai.\nTag ({% %}) → Logic likhne ke liye.\nFilter (|) → Data modify karta hai.\nContext → View se Template me bheja gaya data (Dictionary).\nrender() → Template + Context = HTML.\nDIRS → Template folder ka path.\nAPP_DIRS=True → Apps ke templates bhi search karega.\n{% load static %} → CSS, JS, Images use karne ke liye.\n{{ student.name }} → Dot notation se Dictionary/Object/List access kar sakte hain.",
      "autoResize": true,
      "lineHeight": 1.25
    },
